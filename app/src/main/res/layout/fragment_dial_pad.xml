<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >



    <TextView
        android:id="@+id/tvNumber"
        android:layout_width="0dp"
        android:layout_marginBottom="20dp"
        android:layout_height="60dp"
        android:gravity="center"
        android:hint="+123456"
        android:textColorHint="@color/text_light"
        android:textColor="@color/bg_dark"
        android:textSize="40sp"
        app:layout_constraintBottom_toTopOf="@+id/keypad"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"

         />



    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="70dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toTopOf="@+id/btnCall"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        >


        <Button
            android:id="@+id/btn1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="1"
            android:textSize="30dp"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="2"
            android:textSize="30dp"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="3"
            android:textSize="30dp"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn4"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:textSize="30dp"
            android:text="4"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:textSize="30dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="5"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:textSize="30dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="6"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn7"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:textSize="30dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="7"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:textSize="30dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:background="@drawable/bg_circle"
            android:text="8"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:textSize="30dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="9"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btnStar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:textSize="30dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="*"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:text="0"
            android:textSize="30dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btnHash"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:textSize="30dp"
            android:background="@drawable/bg_circle"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:text="#"
            android:textColor="@color/text_white" />
    </GridLayout>


    <ImageView
        android:id="@+id/btnCall"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_circle"
        android:layout_marginBottom="70dp"
        android:backgroundTint="@color/green_call"
        android:padding="20dp"
        android:src="@android:drawable/ic_menu_call"
        app:layout_constraintBottom_toBottomOf="parent"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
         />

    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="43dp"
        android:layout_height="47dp"
        android:layout_margin="80dp"
        android:layout_marginEnd="56dp"
        android:background="@color/text_light"
        android:src="@drawable/outline_backspace_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/keypad"
        app:layout_constraintVertical_bias="0.346" />



</androidx.constraintlayout.widget.ConstraintLayout>